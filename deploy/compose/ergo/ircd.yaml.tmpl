# Ergo ircd.yaml — generated by entrypoint from environment variables.
# Do not edit this file directly; edit ircd.yaml.tmpl instead.

network:
  name: ${ERGO_NETWORK_NAME}

server:
  name: ${ERGO_SERVER_NAME}
  listeners:
    ":6667":
      # plaintext IRC — internal Docker network only, not published
  casemapping: "ascii"
  enforce-utf8: true
  lookup-hostnames: false
  forward-confirm-hostnames: false
  check-ident: false
  relaymsg:
    enabled: false
  ip-cloaking:
    enabled: false
  max-sendq: "1M"
  ip-limits:
    count-exempted: true
    throttle-exempted: true

accounts:
  authentication-enabled: true
  registration:
    enabled: true
    allow-before-connect: true
    throttling:
      enabled: false
    bcrypt-cost: 4
    email-verification:
      enabled: false
  nick-reservation:
    enabled: true
    additional-nick-limit: 0
    method: strict
    allow-custom-enforcement: false
  multiclient:
    enabled: true
    allowed-by-default: true
    always-on: opt-out
    auto-away: opt-out

channels:
  default-modes: +ntC
  registration:
    enabled: true

datastore:
  path: /ircd/ircd.db

history:
  enabled: true
  channel-length: 256
  client-length: 64
  autoresize-window: 1d
  autoreplay-on-join: 0
  chathistory-limit: 100
  znc-maxmessages: 2048
  restrictions:
    expire-time: 1w
    query-cutoff: none
  persistent:
    enabled: ${ERGO_HISTORY_ENABLED}
    unregistered-channels: false
    registered-channels: opt-in
    direct-messages: opt-in
    connection-string: ${ERGO_HISTORY_DSN}

api:
  enabled: true
  listen: "0.0.0.0:8089"
  bearer-tokens:
    - ${ERGO_API_TOKEN}

logging:
  - method: stderr
    type: "*"
    level: warn
